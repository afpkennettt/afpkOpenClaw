{
  session: {
    dmScope: "per-channel-peer",
  },
  agents: {
    defaults: {
      model: {
        primary: "openai/gpt-5.1-codex",
      },
      models: {
        "openai/gpt-5.1-codex": {
          alias: "GPT",
        },
      },
    },
  },
  channels: {
    whatsapp: {
      dmPolicy: "pairing",
      groupPolicy: "allowlist",
      groups: {
        "*": {
          requireMention: true,
        },
      },
    },
  },
  web: {
    enabled: true,
    heartbeatSeconds: 60,
    reconnect: {
      initialMs: 2000,
      maxMs: 120000,
      factor: 1.4,
      jitter: 0.2,
      maxAttempts: 0,
    },
  },
  discovery: {
    mdns: {
      mode: "off",
    },
    wideArea: {
      enabled: false,
    },
  },
  gateway: {
    mode: "local",
    port: 18789,
    bind: "lan",
    auth: {
      mode: "token",
      allowTailscale: false,
      rateLimit: {
        maxAttempts: 10,
        windowMs: 60000,
        lockoutMs: 300000,
        exemptLoopback: false,
      },
    },
    controlUi: {
      enabled: true,
      allowedOrigins: [
        "http://127.0.0.1:18789",
        "http://localhost:18789",
      ],
    },
    tools: {
      deny: [
        "browser",
        "canvas",
        "exec",
        "process",
        "gateway",
        "cron",
        "nodes",
        "sessions_send",
        "sessions_spawn",
      ],
    },
  },
  browser: {
    enabled: false,
    evaluateEnabled: false,
    ssrfPolicy: {
      dangerouslyAllowPrivateNetwork: false,
    },
  },
  canvasHost: {
    enabled: false,
  },
  tools: {
    profile: "coding",
    deny: [
      "group:runtime",
      "group:automation",
      "group:nodes",
      "browser",
      "canvas",
      "sessions_send",
      "sessions_spawn",
    ],
    fs: {
      workspaceOnly: true,
    },
    exec: {
      applyPatch: {
        workspaceOnly: true,
      },
    },
    elevated: {
      enabled: false,
    },
    loopDetection: {
      enabled: true,
      historySize: 30,
      warningThreshold: 10,
      criticalThreshold: 20,
      globalCircuitBreakerThreshold: 30,
      detectors: {
        genericRepeat: true,
        knownPollNoProgress: true,
        pingPong: true,
      },
    },
  },
}
